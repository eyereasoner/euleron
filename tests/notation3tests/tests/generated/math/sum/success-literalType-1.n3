@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#math:sum

# Testing the data type casting capabilities of the reasoner.
# Reference: https://w3c.github.io/N3/spec/builtins.html#typesofdatatypecasting
# Reference: https://www.w3.org/TR/xpath-functions/#casting

# success-literalType-1 
{
    ("1"^^xsd:integer "2"^^xsd:integer "3"^^xsd:integer "4"^^xsd:integer "5"^^xsd:integer "6"^^xsd:integer "7"^^xsd:integer "8"^^xsd:integer "9"^^xsd:integer "10"^^xsd:integer) math:sum "55"^^xsd:integer.
}
=>
{
    :result :has :success-literalType-1.
}.

{ } => {
    :test :contains :success-literalType-1.
}.

{
    :result :has :success-literalType-1.
}
=>
{
    :test :is true.
}.
