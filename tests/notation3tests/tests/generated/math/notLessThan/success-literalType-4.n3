@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#math:notLessThan

# Testing the data type casting capabilities of the reasoner.
# Reference: https://w3c.github.io/N3/spec/builtins.html#typesofdatatypecasting
# Reference: https://www.w3.org/TR/xpath-functions/#casting

# success-literalType-4 
{
    "2"^^xsd:double math:notLessThan "1"^^xsd:double.
}
=>
{
    :result :has :success-literalType-4.
}.

{ } => {
    :test :contains :success-literalType-4.
}.

{
    :result :has :success-literalType-4.
}
=>
{
    :test :is true.
}.
