@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#math:cos

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-1 
{
    0.0 math:cos 1.0.
}
=>
{
    :result :has :success-literal-1.
}.

{ } => {
    :test :contains :success-literal-1.
}.

{
    :result :has :success-literal-1.
}
=>
{
    :test :is true.
}.
