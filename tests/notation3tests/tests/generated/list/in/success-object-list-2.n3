@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#list:in

# Testing the built-in with a literal value on the subject and an rdf list in object position.

:test :value [ rdf:first "42"^^xsd:float ;
  rdf:rest [ rdf:first 42e0 ;
             rdf:rest [ rdf:first "42"^^xsd:integer ;
                        rdf:rest rdf:nil ] ] ].

# success-object-list-2 
{
    :test :value ?TestValue.
    42 list:in ?TestValue.
}
=>
{
    :result :has :success-object-list-2.
}.

{ } => {
    :test :contains :success-object-list-2.
}.

{
    :result :has :success-object-list-2.
}
=>
{
    :test :is true.
}.
