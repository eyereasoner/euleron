@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#list:in

# Check if the subject accepts a not instantiated variable and check the instantiated output.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

# success-subjectNotInstantiated-2 
{
    ?X list:in ("dog" "cat" "penguin").
}
=>
{
    :check_success-subjectNotInstantiated-2 :value "cat".
    {
        :check_success-subjectNotInstantiated-2 :value ?X .
    }
    =>
    {
        :result :has :success-subjectNotInstantiated-2.
    }.
}.

{ } => {
    :test :contains :success-subjectNotInstantiated-2.
}.

{
    :result :has :success-subjectNotInstantiated-2.
}
=>
{
    :test :is true.
}.
