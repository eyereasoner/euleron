@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#list:append

# Testing the built-in with an rdf list on the subject and a literal in object position.

:test :value [ rdf:first rdf:nil ;
  rdf:rest [ rdf:first rdf:nil ;
             rdf:rest rdf:nil ] ].

# success-subject-list-2 
{
    :test :value ?TestValue.
    ?TestValue list:append ().
}
=>
{
    :result :has :success-subject-list-2.
}.

{ } => {
    :test :contains :success-subject-list-2.
}.

{
    :result :has :success-subject-list-2.
}
=>
{
    :test :is true.
}.
