@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#list:remove

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-2 
{
    (("dog" "cat" "penguin") "parkeet") list:remove ("dog" "cat" "penguin").
}
=>
{
    :result :has :success-literal-2.
}.

{ } => {
    :test :contains :success-literal-2.
}.

{
    :result :has :success-literal-2.
}
=>
{
    :test :is true.
}.
