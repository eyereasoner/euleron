@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#list:memberAt

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-3 
{
    (("dog" 42 "penguin") "1"^^xsd:integer) list:memberAt "42"^^xsd:integer.
}
=>
{
    :result :has :success-literal-3.
}.

{ } => {
    :test :contains :success-literal-3.
}.

{
    :result :has :success-literal-3.
}
=>
{
    :test :is true.
}.
