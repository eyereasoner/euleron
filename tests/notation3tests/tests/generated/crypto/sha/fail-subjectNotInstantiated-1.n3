@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix crypto: <http://www.w3.org/2000/10/swap/crypto#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#crypto:sha

# Check if the subject accepts a not instantiated variable.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

# fail-subjectNotInstantiated-1 
{
    ?X crypto:sha "2aae6c35c94fcfb415dbe95f408b9ce91ee846ed".
    _:x crypto:sha "2aae6c35c94fcfb415dbe95f408b9ce91ee846ed".
}
=>
{
    :result :has :fail-subjectNotInstantiated-1.
}.

{ } => {
    :test :contains :fail-subjectNotInstantiated-1.
}.

{
    :result :has :fail-subjectNotInstantiated-1.
}
=>
{
    :test :is false.
}.
