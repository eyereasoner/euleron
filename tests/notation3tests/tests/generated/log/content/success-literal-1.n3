@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:content

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-1 @pragma networking
{
    <https://codeberg.org/phochste/notation3tests/raw/branch/main/HELLO.txt> log:content "Hello, world!\n".
}
=>
{
    :result :has :success-literal-1.
}.

{ } => {
    :test :contains :success-literal-1.
}.

{
    :result :has :success-literal-1.
}
=>
{
    :test :is true.
}.
