@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:uri

# Check if the built-in accepts non instantiated wildcards both in subject and object position.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

# success-fullNotInstantiated-1 
{
    ?X log:uri ?Y.
    _:x log:uri _:y.
}
=>
{
    {
      ?X log:uri "urn:foo:bar".
    }
    =>
    {
        {
            <urn:foo:bar> log:uri ?Y.
        }   
        =>
        {
            :result :has :success-fullNotInstantiated-1.
        }.
    }.
}.

{ } => {
    :test :contains :success-fullNotInstantiated-1.
}.

{
    :result :has :success-fullNotInstantiated-1.
}
=>
{
    :test :is true.
}.
