@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:semantics

# Check if the object accepts a not instantiated variable.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

# success-objectNotInstantiated-1 @pragma networking
{
    <https://codeberg.org/phochste/notation3tests/raw/branch/main/HELLO.n3> log:semantics ?X.
    <https://codeberg.org/phochste/notation3tests/raw/branch/main/HELLO.n3> log:semantics _:x.
}
=>
{
    :result :has :success-objectNotInstantiated-1.
}.

{ } => {
    :test :contains :success-objectNotInstantiated-1.
}.

{
    :result :has :success-objectNotInstantiated-1.
}
=>
{
    :test :is true.
}.
