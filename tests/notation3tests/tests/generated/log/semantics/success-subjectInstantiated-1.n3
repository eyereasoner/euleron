@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:semantics

# Check if the subject accepts a bound variable.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

:check_success-subjectInstantiated-1 :value <https://codeberg.org/phochste/notation3tests/raw/branch/main/HELLO.n3>.
# success-subjectInstantiated-1 @pragma networking
{
    :check_success-subjectInstantiated-1 :value ?X.
    ?X log:semantics { :Hello a :World. }.
}
=>
{
    :result :has :success-subjectInstantiated-1.
}.

{ } => {
    :test :contains :success-subjectInstantiated-1.
}.

{
    :result :has :success-subjectInstantiated-1.
}
=>
{
    :test :is true.
}.
