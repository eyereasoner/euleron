@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:equalTo

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-23 
{
    { :a :b :c. :d :e 1. } log:equalTo { :d :e "1"^^xsd:integer. :a :b :c. }.
}
=>
{
    :result :has :success-literal-23.
}.

{ } => {
    :test :contains :success-literal-23.
}.

{
    :result :has :success-literal-23.
}
=>
{
    :test :is true.
}.
