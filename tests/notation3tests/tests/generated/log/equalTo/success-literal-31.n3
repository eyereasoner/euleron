@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:equalTo

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-31 
{
    "\t\b\n\r\f\"\'\\" log:equalTo "\u0009\u0008\u000A\u000D\u000C\u0022\u0027\u005C".
}
=>
{
    :result :has :success-literal-31.
}.

{ } => {
    :test :contains :success-literal-31.
}.

{
    :result :has :success-literal-31.
}
=>
{
    :test :is true.
}.
