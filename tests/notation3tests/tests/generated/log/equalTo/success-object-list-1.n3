@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:equalTo

# Testing the built-in with a literal value on the subject and an rdf list in object position.

:test :value [ rdf:first "1"^^xsd:integer ;
  rdf:rest [ rdf:first "2"^^xsd:integer ;
             rdf:rest [ rdf:first 3 ;
                        rdf:rest rdf:nil ] ] ].

# success-object-list-1 
{
    :test :value ?TestValue.
    (1 2 3) log:equalTo ?TestValue.
}
=>
{
    :result :has :success-object-list-1.
}.

{ } => {
    :test :contains :success-object-list-1.
}.

{
    :result :has :success-object-list-1.
}
=>
{
    :test :is true.
}.
