@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:notIncludes

# Testing the data type casting capabilities of the reasoner.
# Reference: https://w3c.github.io/N3/spec/builtins.html#typesofdatatypecasting
# Reference: https://www.w3.org/TR/xpath-functions/#casting

# fail-literalType-1 
{
    "{ :a :b :c. }"^^xsd:foobar log:notIncludes "{ :A :b :c. }"^^xsd:barfoo.
}
=>
{
    :result :has :fail-literalType-1.
}.

{ } => {
    :test :contains :fail-literalType-1.
}.

{
    :result :has :fail-literalType-1.
}
=>
{
    :test :is false.
}.
