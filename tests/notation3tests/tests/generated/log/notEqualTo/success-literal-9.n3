@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:notEqualTo

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-9 
{
    (1 2 (3 4 (5 (6 (7 (8 9)))))) log:notEqualTo (1 2 (3 4 (5 (6 (7 (8 :boom)))))).
}
=>
{
    :result :has :success-literal-9.
}.

{ } => {
    :test :contains :success-literal-9.
}.

{
    :result :has :success-literal-9.
}
=>
{
    :test :is true.
}.
