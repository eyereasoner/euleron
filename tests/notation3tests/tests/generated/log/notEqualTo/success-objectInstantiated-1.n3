@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:notEqualTo

# Check if the object accepts a bound variable.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

:check_success-objectInstantiated-1 :value -1.
# success-objectInstantiated-1 
{
    :check_success-objectInstantiated-1 :value ?X.
    1 log:notEqualTo ?X.
}
=>
{
    :result :has :success-objectInstantiated-1.
}.

{ } => {
    :test :contains :success-objectInstantiated-1.
}.

{
    :result :has :success-objectInstantiated-1.
}
=>
{
    :test :is true.
}.
