@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:notEqualTo

# Testing the built-in with valid literal values on the subject and object position.

# fail-literal-12 
{
    "2025-15-87"^^xsd:date log:notEqualTo "2025-15-87"^^xsd:date.
}
=>
{
    :result :has :fail-literal-12.
}.

{ } => {
    :test :contains :fail-literal-12.
}.

{
    :result :has :fail-literal-12.
}
=>
{
    :test :is false.
}.
