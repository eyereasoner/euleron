@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2000/10/swap/time#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#time:second

# Check if the object accepts a not instantiated variable.
# Reference: https://w3c-cg.github.io/n3Builtins/#argumentmodes

# success-objectNotInstantiated-1 
{
    "2023-04-01T18:06:04Z"^^xsd:dateTime time:second ?X.
    "2023-04-01T18:06:04Z"^^xsd:dateTime time:second _:x.
}
=>
{
    :result :has :success-objectNotInstantiated-1.
}.

{ } => {
    :test :contains :success-objectNotInstantiated-1.
}.

{
    :result :has :success-objectNotInstantiated-1.
}
=>
{
    :test :is true.
}.
