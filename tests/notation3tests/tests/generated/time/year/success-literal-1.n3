@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix time: <http://www.w3.org/2000/10/swap/time#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#time:year

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-1 
{
    "1971-04-01T18:06:04Z"^^xsd:dateTime time:year 1971.
}
=>
{
    :result :has :success-literal-1.
}.

{ } => {
    :test :contains :success-literal-1.
}.

{
    :result :has :success-literal-1.
}
=>
{
    :test :is true.
}.
