@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#string:containsIgnoringCase

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-15 cast date to string
{
    "In 1971-05-05T18:59:12Z Pat was born" string:containsIgnoringCase "1971-05-05T18:59:12Z"^^xsd:dateTime.
}
=>
{
    :result :has :success-literal-15.
}.

{ } => {
    :test :contains :success-literal-15.
}.

{
    :result :has :success-literal-15.
}
=>
{
    :test :is true.
}.
