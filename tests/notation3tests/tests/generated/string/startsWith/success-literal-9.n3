@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#string:startsWith

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-9 cast dateTime to string
{
    "2000-01-02T03:04:05Z"^^xsd:dateTime string:startsWith "2000".
}
=>
{
    :result :has :success-literal-9.
}.

{ } => {
    :test :contains :success-literal-9.
}.

{
    :result :has :success-literal-9.
}
=>
{
    :test :is true.
}.
