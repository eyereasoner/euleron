@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#string:equalIgnoringCase

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-21 cast typed literal to string
{
    "ZZZZ" string:equalIgnoringCase "zZZz"^^:t1.
}
=>
{
    :result :has :success-literal-21.
}.

{ } => {
    :test :contains :success-literal-21.
}.

{
    :result :has :success-literal-21.
}
=>
{
    :test :is true.
}.
