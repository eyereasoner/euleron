@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#string:concatenation

# Testing the built-in with an rdf list on the subject and a literal in object position.

:test :value [ rdf:first "<"^^:t1 ;
  rdf:rest [ rdf:first ">"^^:t2 ;
             rdf:rest rdf:nil ] ].

# success-subject-list-9 cast typed literal to string
{
    :test :value ?TestValue.
    ?TestValue string:concatenation "<>".
}
=>
{
    :result :has :success-subject-list-9.
}.

{ } => {
    :test :contains :success-subject-list-9.
}.

{
    :result :has :success-subject-list-9.
}
=>
{
    :test :is true.
}.
