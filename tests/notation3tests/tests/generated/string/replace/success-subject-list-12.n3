@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#string:replace

# Testing the built-in with an rdf list on the subject and a literal in object position.

:test :value [ rdf:first 1.234 ;
  rdf:rest [ rdf:first "3"^^xsd:float ;
             rdf:rest [ rdf:first "88"^^xsd:float ;
                        rdf:rest rdf:nil ] ] ].

# success-subject-list-12 case decimal and double to string
{
    :test :value ?TestValue.
    ?TestValue string:replace "1.2884".
}
=>
{
    :result :has :success-subject-list-12.
}.

{ } => {
    :test :contains :success-subject-list-12.
}.

{
    :result :has :success-subject-list-12.
}
=>
{
    :test :is true.
}.
