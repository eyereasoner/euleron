@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#string:replace

# Testing the built-in with an rdf list on the subject and a literal in object position.

:test :value [ rdf:first "{{tar{{target}}get}}" ;
  rdf:rest [ rdf:first "{{target}}" ;
             rdf:rest [ rdf:first "{over}" ;
                        rdf:rest rdf:nil ] ] ].

# success-subject-list-4 
{
    :test :value ?TestValue.
    ?TestValue string:replace "{{tar{over}get}}".
}
=>
{
    :result :has :success-subject-list-4.
}.

{ } => {
    :test :contains :success-subject-list-4.
}.

{
    :result :has :success-subject-list-4.
}
=>
{
    :test :is true.
}.
