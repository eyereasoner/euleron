# Reference: https://w3c-cg.github.io/n3Builtins/#string:matches

# Testing the built-in with valid literal values on the subject and object position.

# success-literal-6 
{
    "γειαα κόσμο!" string:matches "^\\p{Ll}{5}\\x20\\p{L}{5}\\p{P}$".
}
=>
{
    :result :has :success-literal-6.
}.

{ } => {
    :test :contains :success-literal-6.
}.

{
    :result :has :success-literal-6.
}
=>
{
    :test :is true.
}.
