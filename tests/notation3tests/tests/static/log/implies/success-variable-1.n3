:x :y { :x :y { :x :y { :x :y 42 } } }.

{
    :x :y { :x :y { :x :y { :x :y ?C } } } .
}
=>
{
    {
        ( ?C 42 ) math:difference 0. 
    }
    =>
    {
        :result :has :success-variable-1.
    }.
}.

{} => {
    :test :contains :success-variable-1.
}.

{
    :result :has :success-variable-1.
}
=>
