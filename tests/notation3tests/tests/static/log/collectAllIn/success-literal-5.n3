@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@base <http://example.org/>.

# Reference: https://w3c-cg.github.io/n3Builtins/#log:collectAllIn

:Let :param [ :param [ :param "Louie" ] ].

# success-literal-5
{
    ( 
        { 
            :L!:p :p ?X.
        } 
        { 
            :Let!:param!:param :param ?X. 
        } 
        ?allParams
    ) log:collectAllIn _:x.
}
=>
{
    :foo :bar ?allParams.

    {
        :foo :bar ?L.

        # Use member here, because collectAllIn is dependent on ordering of triples
        ?L list:member { :L!:p :p "Louie" }.
    }
    =>
    {
        :result :has :success-literal-5.
    }.
}.

{ } => {
    :test :contains :success-literal-5.
}.

{
    :result :has :success-literal-5.
}
=>
{
    :test :is true.
}.