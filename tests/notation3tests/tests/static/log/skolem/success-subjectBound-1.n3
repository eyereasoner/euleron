:check_success-subjectBound-1 :value ({ :a :b :c. } { :d :e :f. } 17 :foo ()).
# success-subjectBound-1
{
    :check_success-subjectBound-1 :value ?X.
    ?X log:skolem ?Y.
}
=>
{
    :result :has :success-subjectBound-1.
}.

{ } => {
    :test :contains :success-subjectBound-1.
}.

{
    :result :has :success-subjectBound-1.
