@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@base <http://example.org/>.

# Reference: https://w3c.github.io/N3/spec/builtins.html#log:skolem

# success-objectUnbound-1
{
    ({ :a :b :c. } { :d :e :f. } 17 :foo ()) log:skolem ?X.
    ({ :a :b :c. } { :d :e :f. } 17 :foo ()) log:skolem _:x.
}
=>
{
    :result :has :success-objectUnbound-1.
}.

{ } => {
    :test :contains :success-objectUnbound-1.
}.

{
    :result :has :success-objectUnbound-1.
}
=>
{
    :test :is true.
}.
