@prefix : <http://example.org/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@base <http://example.org/>.

# Reference: https://w3c.github.io/N3/spec/builtins.html#log:uri

# Faulty implementation will produce gibberish
# If no gibberish is produced then the test is ok
{
    ?X log:uri "p>. <a> <b> <c> <d> <e> <".
}
=>
{
  	:foo :bar ?X.
}.

{ } => {
    :test :contains :success-literal-1.
    :result :has :success-literal-1.
    :test :is true.
}.