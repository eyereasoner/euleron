@prefix : <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Reference: https://w3c.github.io/N3/spec/#paths

:a :b [ :c [ :d [ :value 42 ] ]].

{
   :a!:b!:c!:d :value 42.
}
=>
{
    :result :has :success-literal-8.
}.

{} => {
    :test :contains :success-literal-8.
}.

{
    :result :has :success-literal-8.
}
=>
{
    :test :is true.
}.