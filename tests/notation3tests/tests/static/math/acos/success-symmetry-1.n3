@prefix : <http://example.org/> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .

# Reference: https://w3c.github.io/N3/spec/builtins.html#math:acos

:input :val 0.2171.

{
    -1 math:acos ?PI.
    
    :input :val ?X.
    ?X math:acos ?Y.
    (?PI ?Y) math:difference ?A.

    ?X!math:negation math:acos ?A.
}
=>
{
    :result :has :success-symmetry-1.
}.

{} => {
    :test :contains :success-symmetry-1.
}.

{
    :result :has :success-symmetry-1.
}
=>
{
    :test :is true.
}.