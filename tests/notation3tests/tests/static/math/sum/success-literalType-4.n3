@prefix : <http://example.org/> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Reference: https://w3c.github.io/N3/spec/builtins.html#math:sum

{
    (1.1 1.1) math:sum "2.2"^^xsd:decimal .
}
=>
{
    :result :has :success-literalType-4.
}.

{} => {
    :test :contains :success-literalType-4.
}.

{
    :result :has :success-literalType-4.
}
=>
{
    :test :is true.
}.