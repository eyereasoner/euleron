@prefix : <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Reference: https://w3c.github.io/N3/spec/builtins.html#typesofdatatypecasting
# Reference: https://www.w3.org/TR/xpath-functions/#casting

:x :y "1.234567890"^^xsd:decimal.

{
    :x :y 1.234567890.
}
=>
{
    :result :has :success-literalType-4.
}.

{} => {
    :test :contains :success-literalType-4.
}.

{
    :result :has :success-literalType-4.
}
=>
{
    :test :is true.
}.