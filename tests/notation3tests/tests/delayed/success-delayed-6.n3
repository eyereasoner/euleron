@prefix : <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .

# Testing if the reasoner supports unordered sets of triples in the
# premise position of log:implies.
# Reference: https://w3c.github.io/N3/spec/semantics.html#terms-triples-and-graphs

{
  (?A ?B ?C) list:iterate (?X ?B).
  (?A ?B ?C) list:iterate (?Y ?A).
  (?A ?B ?C) list:iterate (?Z ?C).
  (?X ?Y ?Z) list:iterate (?B ?X).
  (?X ?Y ?Z) list:iterate (?A ?Y).
  (?X ?Y ?Z) list:iterate (?C ?Z).
}
=>
{
    :result :has :success-delayed-6.
}.

{} => {
    :test :contains :success-delayed-6.
}.

{
    :result :has :success-delayed-6.
}
=>
{
    :test :is true.
}.