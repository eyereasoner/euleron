@prefix : <http://example.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@prefix list: <http://www.w3.org/2000/10/swap/list#> .

# Testing if the reasoner supports unordered sets of triples in the
# premise position of log:implies.
# Reference: https://w3c.github.io/N3/spec/semantics.html#terms-triples-and-graphs

{
  ?X math:greaterThan -0.5.
  ?X math:cos ?Y.
  ?X math:lessThan 0.5.
  (1) list:iterate (?I ?Y).
}
=>
{
    :result :has :success-delayed-2.
}.

{} => {
    :test :contains :success-delayed-2.
}.

{
    :result :has :success-delayed-2.
}
=>
{
    :test :is true.
}.